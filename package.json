{
  "name": "playwright-e2e-demo",
  "version": "1.0.0",
  "description": "Senior-level Playwright + TypeScript E2E automation framework (Page Object Model, fixtures, data-driven tests, cross-browser, CI, Allure) against the public Swag Labs demo site.",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "keywords": [
    "playwright",
    "typescript",
    "e2e",
    "test-automation",
    "qa-automation",
    "page-object-model",
    "ci"
  ],
  "author": "Nick Liapin",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "allure-playwright": "^3.0.4",
    "typescript": "^5.6.2"
  }
}
